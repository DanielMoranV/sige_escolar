{
  "name": "sige-escolar",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:admin\"",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "npx ts-node -r tsconfig-paths/register prisma/seed/index.ts",
    "db:reset": "npx ts-node scripts/drop-all-schemas.ts && npx prisma migrate reset --schema=prisma/schema.prisma --force && npm run db:seed",
    "db:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "tenant:create": "npx ts-node scripts/create-tenant.ts",
    "demo:seed": "npx ts-node -r tsconfig-paths/register scripts/demo/seed-demo.ts",
    "demo:drop": "npx ts-node -r tsconfig-paths/register scripts/demo/drop-demo.ts",
    "demo:reset": "npx ts-node -r tsconfig-paths/register scripts/demo/reset-demo.ts",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"**/*.{ts,vue,json}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
